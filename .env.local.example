# Supabase credentials
# Create a project at https://supabase.com and paste the values below.

# Public URL of the Supabase project (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose client-side, limited by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (NEVER expose to the client - server-only).
# Used by src/lib/supabase/admin.ts to bypass RLS while auth is still mocked.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: log level for Pino (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info
